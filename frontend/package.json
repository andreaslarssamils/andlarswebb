{
  "name": "frontend_nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:local": "IGNORE_SENTRY=1 next build",
    "start": "PORT=3000 node .next/standalone/server.js",
    "storybook": "storybook dev -p 3001",
    "build-storybook": "storybook build",
    "fixcode": "prettier --write .",
    "fixcode:check": "prettier --check .",
    "new": "node cli/bin.js new",
    "new:container": "node cli/bin.js new --container",
    "test": "jest --watch",
    "test:ci": "jest --ci --runInBand --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "i18next": "^26.2.0",
    "next": "16.2.7",
    "next-i18next": "^16.0.7",
    "prop-types": "^15.8.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.8"
  },
  "//overrides": "Force postcss>=8.5.10 everywhere - GHSA-qx2v-qp2m-jg93 - remove when next ships with postcss>=8.5.10",
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.17",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "storybook": "^10.2.17",
    "@storybook/nextjs-vite": "10.4.2"
  }
}
